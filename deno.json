{
  "imports": {
    "hono": "jsr:@hono/hono@^4.8.3"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-sys --allow-read main.tsx",
    "dev": "deno run --allow-net --allow-sys --allow-read --watch main.tsx"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "deploy": {
    "project": "nhwc",
    "exclude": [
      "**/node_modules"
    ],
    "include": [],
    "entrypoint": "main.tsx"
  }
}